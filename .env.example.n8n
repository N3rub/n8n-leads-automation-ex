#
# .env.example.n8n
#

# BASE DE DATOS
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_db # BD exclusiva del motor n8n
# Workflows de leads usan: leads_db (creada por postgres/migrations/000_create_databases.sh)
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=n8n_app_password
DB_POSTGRESDB_SSL_ENABLED=false

# COLA (Redis / Bull Queue)
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=redis_password
QUEUE_BULL_REDIS_DB=0
QUEUE_RECOVERY_INTERVAL=60

# SEGURIDAD
# Generar: openssl rand -base64 32
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_KEY_HERE
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_JWT_SECRET_HERE

# TELEMETRIA
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false

# ACTUALIZACIONES
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# AUTENTICACIÓN UI
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_UI_PASSWORD

# URL PÚBLICA
WEBHOOK_URL=http://localhost
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http

# MODO DE EJECUCIÓN
EXECUTIONS_MODE=queue
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true

# LOGS
N8N_LOG_LEVEL=warn
N8N_LOG_OUTPUT=console

# MÉTRICAS (Prometheus)
N8N_METRICS=true
N8N_METRICS_PREFIX=n8n_
N8N_METRICS_INCLUDE_DEFAULT_METRICS=true
N8N_METRICS_INCLUDE_WORKFLOW_ID_LABEL=true

# TIMEZONE
GENERIC_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid

# LÍMITES
N8N_PAYLOAD_SIZE_MAX=16
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=720
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=false

# CUSTOM NODES
N8N_CUSTOM_EXTENSIONS=/home/node/.n8n/custom

# GRAFANA (usado en docker-compose directamente)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_password
