#
# .env.example.postgres
#

# Superusuario (solo para init; la app usa n8n_user)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=n8n_db

# Usuario de aplicación (n8n + workflows de leads)
APP_DB_USER=n8n_user
APP_DB_PASSWORD=n8n_app_password

# Usuario de solo lectura (Grafana / monitorización)
READONLY_DB_USER=grafana_reader
READONLY_DB_PASSWORD=grafana_reader_password

POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=en_US.UTF-8
PGDATA=/var/lib/postgresql/data/pgdata
